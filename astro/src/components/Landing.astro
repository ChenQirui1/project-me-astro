---
import astroLogo from "../assets/astro.svg";
import { Picture } from "astro:assets";
import background from "../assets/background.svg";
import Socials from "./Socials.astro";
import LandingBg from "../assets/gallery/test-image.png";
import Image from "astro/components/Image.astro";
import ProjectView from "../views/ProjectView.astro";
import GalleryView from "../views/GalleryView.astro";
import Navbar from "./Navbar.astro";
---

<div id="container">
  <main>
    <div class="sections">
      <section id="intro">
        <div class="bg">
          <Picture src={LandingBg} width={1000} alt="Landing background" />
        </div>
        <div class="intro-content">
          <h2>INTERACTION DESIGNER</h2>
          <h1>RUI</h1>
        </div>
      </section>
      <Navbar />
      <!-- <TestNavbar /> -->
      <!-- Projects Section Preview -->
      <section
        class="section-preview"
        id="projects"
        transition:name="projects-section"
      >
        <ProjectView />
      </section>
      <!-- Gallery Section Preview -->
      <section
        class="section-preview"
        id="gallery"
        transition:name="gallery-section"
      >
        <GalleryView />
      </section>
    </div>
  </main>
</div>

<style>
  #container {
    min-height: 100vh;
  }

  .sections {
    display: flex;
    flex-direction: column;
  }

  #intro {
    position: relative;
    height: 100vh;
    display: flex;
    width: 100%;
    padding: 2rem 0;
  }

  .intro-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    gap: 1rem;
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    padding: 2rem;
  }

  .bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  #intro h1 {
    font-size: 10rem;
    font-weight: 600;
    margin: 0;
    line-height: 0.8;
    width: fit-content;
  }

  #intro h2 {
    font-size: 3rem;
    font-weight: 400;
    margin: 0;
    text-align: end;
  }

  #socials {
    justify-self: flex-end;
    align-self: flex-end;
  }

  @media screen and (min-width: 768px) {
    #intro h1 {
      font-size: 20rem;
    }

    h2 {
      font-size: 3rem;
    }

    .intro-content {
      padding: 4rem;
    }

    .section-preview {
      padding: 4rem;
    }
  }
</style>
