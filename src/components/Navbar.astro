<style lang="scss">
  $primary-color: black;
  $text-color: white;
  $hover-color: #333;
  $transition-timing: 0.5s linear;
  $mobile-breakpoint: 768px;

  @mixin transition {
    transition: $transition-timing;
    -o-transition: $transition-timing;
    -ms-transition: $transition-timing;
    -moz-transition: $transition-timing;
    -webkit-transition: $transition-timing;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  nav {
    position: sticky;
    z-index: 1;
    top: 0;
    background-color: $primary-color;
    width: 100%;

    ul {
      list-style: none;
    }
  }

  a {
    color: $text-color;
    font-size: large;
  }

  #nav-collapsed {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 1rem;

    &:hover {
      .menu {
        @include transition;
        transform: rotateZ(90deg);
      }

      #nav-submenu {
        display: flex;
        padding-left: 24px;
      }
    }

    &:not(:hover) {
      .menu {
        @include transition;
      }
    }
  }

  #nav-links {
    width: 200px;
    display: flex;
    flex-direction: row;
    list-style: none;
    padding: 0;
    align-items: center;
  }

  #nav-submenu {
    background-color: $primary-color;
    display: none;
    flex-direction: column;
    align-items: flex-end;
    gap: 3em;
  }

  #nav-sublinks {
    display: flex;
    flex-direction: column;
    gap: 1em;
    align-self: flex-start;
    padding: 0;
  }

  #contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  #cta {
    flex-shrink: 0;
    color: $text-color;
    border: none;
    border-radius: 5px;
    font-size: xx-large;
    cursor: pointer;
    background-color: $primary-color;
    padding: 0;

    &:hover {
      color: $hover-color;
    }
  }

  #navbar {
    display: none;
  }

  @media screen and (min-width: $mobile-breakpoint) {
    #navbar {
      display: flex;
      flex-direction: row;
      gap: 1.5em;
    }

    #nav-collapsed {
      display: none;
    }
  }
</style>

