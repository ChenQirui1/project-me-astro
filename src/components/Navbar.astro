---
import { pathHasLocale } from "astro:i18n";
import Socials from "./Socials.astro";

const navigation = [
  { href: "/", text: "Home" },
  // { href: "/projects", text: ".projects" },
  // { href: "/gallery", text: ".gallery" },
  // { href: "/archive", text: ".archive" },
  { href: "/cv", text: ".cv" },
];

// const projects = import.meta.glob(`../pages/projects/*.astro`);

// console.log(projects);
// .map((project) => {
//   const { title, description, slug } = project.data;
//   return { title, description, slug };
// });

const { page } = Astro.props;
---

<nav>
  <!-- Desktop Navigation -->
  <ul id="navbar">
    {
      navigation.map(({ href, text }) => (
        <li>
          <a
            href={href}
            class="nav-link"
            data-section={href.slice(1) || "home"}
          >
            {text}
          </a>
        </li>
      ))
    }
    <div id="socials">
      <Socials />
    </div>
  </ul>

  <!-- Mobile/Collapsed Navigation -->
  <div id="nav-collapsed">
    <div id="nav-links">
      <a class="menu">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="size-6"
          width="24"
          height="24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m8.25 4.5 7.5 7.5-7.5 7.5"></path>
        </svg>
      </a>
      <a href={`/${page}`} id="current-page-link">.{page}</a>
    </div>

    <div id="nav-submenu">
      <ul id="nav-sublinks">
        {
          navigation.map(({ href, text }) => (
            <li>
              <a
                href={href}
                class="nav-sublink"
                data-section={href.slice(1) || "home"}
              >
                {text}
              </a>
            </li>
          ))
        }
      </ul>

      <div id="contact">
        <button id="cta">GET IN TOUCH</button>
        <div class="socials">
          <!-- Your social icons here -->
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const sections = document.querySelectorAll("section");
  const currentPageLink = document.getElementById("current-page-link");

  const observerOptions = {
    root: null,
    rootMargin: "0px 0px -90% 0px",

    threshold: 0,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const sectionId = entry.target.id;

        // Update the current page link text and href
        if (currentPageLink) {
          currentPageLink.textContent = `.${sectionId}`;
          currentPageLink.href = `/${sectionId}`;
        }
      }
    });
  }, observerOptions);

  // Observe all sections
  sections.forEach((section) => {
    if (section) {
      observer.observe(section);
    }
  });
</script>

