---
import { Image } from "astro:assets";
import horse from "../assets/project/image 1.png";

// import frontmatter details to the component
---

<div class="project-item">
  <div class="project-thumbnail">
    <Image src={horse} alt="image" />
  </div>
  <div class="project-details">
    <h2>title</h2>
    <p>project description</p>

    <div class="tags">
      <span>#horse</span>
      <span>#horse</span>
      <span>#horse</span>
      <span>#horse</span>
    </div>
  </div>
</div>

<style>
  .project-item {
    display: flex;
    flex-direction: column;
    /* padding: 1em; */
  }
  .project-thumbnail {
    background: #d26;
    width: 100%;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid white;
  }
  img {
    width: 100%;
    height: 100%;
    object-position: center;
    object-fit: cover;
  }
  .project-details {
    display: flex;
    flex-direction: column;
    /* padding: 1em; */
  }
  .project-info {
    display: flex;
    align-items: center;
    gap: 1em;
  }

  .tags {
    display: flex;
    gap: 1em;
    align-self: flex-end;
  }
</style>
