---
import { getCollection } from "astro:content";
import ProjectThumbnailCard from "./ProjectThumbnailCard.astro";

// get all project items and thumbnails
const projectItems = await getCollection("projects");
---

<div class="gallery-grid grid">
  <div class="gutter-sizer"></div>
  <div class="grid-sizer"></div>
  {
    projectItems.map((item) => (
      <div class="grid-item">
        <a href={`/project/${item.id}`} class="project-link">
          <ProjectThumbnailCard {...item.data} />
        </a>
      </div>
    ))
  }
  <div class="grid-item grid-item--wide">3</div>
  <div class="grid-item grid-item--long">4</div>
  <div class="grid-item grid-item--long">5</div>
  <div class="grid-item grid-item--long">6</div>
  <div class="grid-item">7</div>
  <div class="grid-item">8</div>
  <div class="grid-item">9</div>
  <div class="grid-item">8</div>
  <div class="grid-item">8</div>
</div>

<script>
  import Masonry from "masonry-layout";

  // Initialize masonry with timeout to allow images to load
  const grid = document.querySelector(".gallery-grid");

  if (grid) {
    // Wait a moment for images to load, then initialize masonry
    setTimeout(() => {
      var msnry = new Masonry(grid, {
        gutter: ".gutter-sizer",
        columnWidth: ".grid-sizer",
        itemSelector: ".grid-item",
        percentPosition: true,
        transitionDuration: "0.3s",
      });

      // Re-layout after a short delay to ensure all images are loaded
      setTimeout(() => {
        if (msnry) {
          msnry.layout();
        }
      }, 500);
    }, 100);
  }
</script>

<style>
  .gallery-grid {
    /* background: #eee; */
    /* max-width: 1200px; */
  }

  /* clearfix */
  .grid:after {
    content: "";
    display: block;
    clear: both;
  }

  .gutter-sizer {
    width: 4%;
  }

  /* ---- grid-item ---- */
  .grid-sizer,
  .grid-item {
    width: 48%;
    height: auto;
    float: left;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    overflow: visible;
  }

  /* Project link styling */
  .project-link {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    border-radius: 8px;
    overflow: hidden;
  }

  .project-link:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  /* Allow ProjectThumbnailCard to determine its own height */
  .grid-item .image-container {
    width: 100%;
  }

  .grid-item .thumbnail {
    width: 100%;
    height: auto !important; /* Override fixed height */
    min-height: unset;
  }

  .grid-item .artwork-image {
    width: 100%;
    height: auto;
    max-width: 100%;
    object-fit: contain; /* Changed from cover to contain to show full image */
  }

  .grid-item--square {
    aspect-ratio: 1/1;
  }

  .grid-item--cinematic {
    aspect-ratio: 16/9;
  }

  .grid-item--wide {
    aspect-ratio: 4/3;
  }
  .grid-item--long {
    aspect-ratio: 3/4;
  }

  .grid-item--height2 {
    height: 200px;
  }
  .grid-item--height3 {
    height: 260px;
  }
  .grid-item--height4 {
    height: 360px;
  }

  @media screen and (min-width: 768px) {
    .grid-sizer,
    .grid-item {
      width: 32%;
    }
    .gutter-sizer {
      width: 2%;
    }
  }

  @media screen and (min-width: 1024px) {
    .grid-sizer,
    .grid-item {
      width: 24%;
    }
    .gutter-sizer {
      width: 1%;
    }
  }

  @media screen and (min-width: 1200px) {
    .grid-sizer,
    .grid-item {
      width: 19%;
    }
    .gutter-sizer {
      width: 1%;
    }
  }
</style>
