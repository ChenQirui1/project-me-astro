---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"projects">["data"];

const { title, year, thumbnail } = Astro.props;

// check if thumbnail image is square, 3/2 or 2/3 aspect ratio for better layout

// const aspectRatio = thumbnail.width / thumbnail.height;

// set default aspect class
// let aspectClass = "square";

// if (aspectRatio > 1 && aspectRatio <= 1.5) {
//   aspectClass = "grid-item--wide";
// } else if (aspectRatio > 1.5) {
//   aspectClass = "grid-item--long";
// }
---

<div>
  <div class="image-container">
    {
      thumbnail && (
        <div class="thumbnail">
          <Image
            src={thumbnail}
            alt={title}
            inferSize={true}
            width={300}
            height={300}
            class="artwork-image"
          />
        </div>
      )
    }
  </div>
  <div class="item-info">
    <h3 class="title">{title}</h3>
    <div class="year">{year}</div>
  </div>
</div>
<style lang="scss">
  /* Main container styles */
  div {
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease;
    height: 100%;

    &:hover {
      transform: translateY(-2px);
    }
  }

  .image-container {
    flex: 1;
    margin-bottom: 1rem;

    .thumbnail {
      // width: 100%;
      height: 200px;
      overflow: hidden;
      // border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      position: relative;

      .artwork-image {
        width: 100%;
        // height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform 0.3s ease;
      }

      &:hover .artwork-image {
        transform: scale(1.05);
      }
    }
  }

  .item-info {
    flex-shrink: 0;
    padding: 0 0.5rem;

    .title {
      font-size: 1rem;
      font-weight: 600;
      margin: 0 0 0.25rem 0;
      color: #333;
      line-height: 1.3;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .year {
      font-size: 0.85rem;
      color: #666;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    .medium {
      font-size: 0.8rem;
      color: #777;
      font-style: italic;
      margin-bottom: 0.5rem;
    }

    .description {
      font-size: 0.85rem;
      line-height: 1.4;
      color: #555;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;

      p {
        margin: 0;
      }
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .image-container .thumbnail {
      height: 180px;
    }

    .item-info {
      .title {
        font-size: 0.95rem;
      }

      .year {
        font-size: 0.8rem;
      }
    }
  }

  @media (min-width: 1024px) {
    .image-container .thumbnail {
      height: 220px;
    }
  }
</style>
