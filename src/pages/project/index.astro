---
import ViewLayout from "../../layouts/ViewLayout.astro";
import Navbar from "../../components/Navbar.astro";
import ProjectMasonry from "../../components/ProjectMasonry.astro";
---

<ViewLayout>
  <div id="container">
    <Navbar page="projects" />
    <main>
      <div class="projects-container">
        <h1>Projects</h1>
        <section id="projects-section">
          <ProjectMasonry />
        </section>
      </div>
    </main>
  </div>
</ViewLayout>

<style lang="scss">
  main {
    margin-top: 4em;
    padding: 2rem;
    min-height: calc(100vh - 4rem);
  }

  .projects-container {
    max-width: 1200px;
    margin: 0 auto;

    h1 {
      font-size: 3rem;
      font-weight: 700;
      margin-bottom: 3rem;
      text-align: center;
      color: #333;
    }
  }

  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }

  #projects-section {
    scroll-margin-top: 6rem; /* Account for navbar height */
  }

  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    .projects-container h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }

    #projects-section {
      scroll-margin-top: 5rem;
    }
  }

  .project-items {
    display: flex;
    flex-direction: column;
    gap: 2em;
    flex-basis: 100%;
    height: calc(100vh - 8em);
    overflow-y: auto;
    overflow-x: hidden;
    padding-right: 1em;

    /* Custom scrollbar styling */
    &::-webkit-scrollbar {
      width: 10px;
      // background-image: linear-gradient(gray 50%, transparent 0%);
      // background-size: 2px 10px;
      // background-repeat: repeat-y;
      // background-position: center;
    }

    &::-webkit-scrollbar-thumb {
      background-image: linear-gradient(white 50%, transparent 0%);
      background-size: 2px 25px;
      background-repeat: repeat-y;
      background-position: center;
      // background-image: linear-gradient(gray 50%, transparent 0%);
      // background: lime;
      // border-radius: 0;
      // width: 10px;

      &:hover {
        background: #90ee90;
      }

      &:active {
        background: #32cd32;
      }
    }
  }
</style>
